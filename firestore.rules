
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getOrg(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data;
    }

    function isOwner(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)) && getOrg(orgId).ownerId == request.auth.uid;
    }

    function getMember(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isMember(orgId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) ||
        isOwner(orgId)
      );
    }

    function hasRole(orgId, roles) {
      return isMember(orgId) && (isOwner(orgId) || getMember(orgId).role in roles);
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isUser(userId);
    }

    // --- Organizations ---
    match /organizations/{organizationId} {
      allow get: if isMember(organizationId);
      allow create: if isSignedIn();
      allow update: if hasRole(organizationId, ['admin']);

      // Staff Management
      match /members/{userId} {
        allow read: if isMember(organizationId) || isUser(userId);
        allow write: if hasRole(organizationId, ['admin']);
      }

      // Invoices
      match /invoices/{invoiceId} {
        allow read: if isMember(organizationId);
        allow create: if hasRole(organizationId, ['admin', 'manager', 'cashier']);
        allow update: if hasRole(organizationId, ['admin', 'manager']);
        allow delete: if hasRole(organizationId, ['admin']);
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if isMember(organizationId);
        allow write: if hasRole(organizationId, ['admin', 'manager']);
        allow delete: if hasRole(organizationId, ['admin']);
      }
    }
  }
}
