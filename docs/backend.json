
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user account.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "Organization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Organization",
      "type": "object",
      "description": "Represents a business or company.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "ownerId",
        "createdAt"
      ]
    },
    "UserOrganization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserOrganization",
      "type": "object",
      "description": "Relationship between User and Organization, specifying a role.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "organizationId": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "manager",
            "cashier"
          ]
        },
        "email": {
          "type": "string",
          "description": "Redundant email for easier list queries."
        }
      },
      "required": [
        "id",
        "userId",
        "organizationId",
        "role"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/organizations/{organizationId}",
        "definition": {
          "entityName": "Organization",
          "schema": {
            "$ref": "#/backend/entities/Organization"
          },
          "description": "Organization details."
        }
      },
      {
        "path": "/organizations/{organizationId}/members/{userId}",
        "definition": {
          "entityName": "UserOrganization",
          "schema": {
            "$ref": "#/backend/entities/UserOrganization"
          },
          "description": "Membership and role within an organization."
        }
      }
    ]
  }
}
