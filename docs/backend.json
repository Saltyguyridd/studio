
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user account.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "organizationId": {
          "type": "string",
          "description": "The ID of the organization the user belongs to."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "Organization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Organization",
      "type": "object",
      "description": "Represents a business or company.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "ownerId",
        "createdAt"
      ]
    },
    "UserOrganization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserOrganization",
      "type": "object",
      "description": "Relationship between User and Organization, specifying a role.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "organizationId": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "manager",
            "cashier"
          ]
        },
        "email": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "userId",
        "organizationId",
        "role"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Unpaid"] },
        "method": { "type": "string" },
        "customerName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "status"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "description"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/User"
      },
      "description": "User profile data."
    },
    "/organizations/{organizationId}": {
      "schema": {
        "$ref": "#/backend/entities/Organization"
      },
      "description": "Organization details."
    },
    "/organizations/{organizationId}/members/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserOrganization"
      },
      "description": "Membership and role within an organization."
    },
    "/organizations/{organizationId}/invoices/{invoiceId}": {
      "schema": {
        "$ref": "#/backend/entities/Invoice"
      },
      "description": "Financial invoices."
    },
    "/organizations/{organizationId}/expenses/{expenseId}": {
      "schema": {
        "$ref": "#/backend/entities/Expense"
      },
      "description": "Business expenses."
    }
  }
}
